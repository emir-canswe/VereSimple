<Page x:Class="VereSimple.Views.CustomersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Müşteriler">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <TextBlock Grid.Row="0" Text="Müşteriler"
                   FontSize="24" FontWeight="Bold"
                   Foreground="#2C3E50" Margin="0,0,0,20"/>

        <!-- Arama + Ekle Butonu -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtSearch"
                     Height="38" FontSize="14" Padding="10,0"
                     BorderBrush="#BDC3C7" BorderThickness="1"
                     VerticalContentAlignment="Center"
                     TextChanged="TxtSearch_TextChanged"/>

            <Button Grid.Column="1" Content="+ Yeni Müşteri"
                    Height="38" Margin="10,0,0,0"
                    Background="#27AE60" Foreground="White"
                    BorderThickness="0" Cursor="Hand" FontSize="13"
                    Click="BtnAddCustomer_Click"/>
        </Grid>

        <!-- Müşteri Listesi -->
        <DataGrid Grid.Row="2" x:Name="CustomersGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#BDC3C7" BorderThickness="1"
                  RowHeight="40" FontSize="13"
                  SelectionMode="Single"
                  CanUserResizeRows="False"
                  AlternatingRowBackground="#F8F9FA">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Ad Soyad" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="130"/>
                <DataGridTextColumn Header="Kalan Borç" Binding="{Binding RemainingDebt, StringFormat={}{0:N2} ₺}" Width="130"/>
                <DataGridTextColumn Header="Kayıt Tarihi" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy}}" Width="120"/>
                <DataGridTemplateColumn Header="İşlemler" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Detay" Width="60" Height="28" Margin="2"
                                        Background="#2980B9" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Tag="{Binding Id}"
                                        Click="BtnDetail_Click"/>
                                <Button Content="Düzenle" Width="65" Height="28" Margin="2"
                                        Background="#F39C12" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Tag="{Binding Id}"
                                        Click="BtnEdit_Click"/>
                                <Button Content="Sil" Width="45" Height="28" Margin="2"
                                        Background="#E74C3C" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Tag="{Binding Id}"
                                        Click="BtnDelete_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>