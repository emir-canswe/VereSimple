<Window x:Class="VereSimple.Views.AddTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="İşlem Ekle" Height="300" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitle" Grid.Row="0"
                   Text="Borç Ekle" FontSize="20" FontWeight="Bold"
                   Foreground="#2C3E50" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Tutar (₺) *" FontSize="13" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtAmount" Height="36" FontSize="14"
                     Padding="8,0" BorderBrush="#BDC3C7"/>

            <TextBlock Text="Açıklama" FontSize="13" Margin="0,12,0,5"/>
            <TextBox x:Name="TxtDescription" Height="60" FontSize="14"
                     Padding="8,5" BorderBrush="#BDC3C7"
                     TextWrapping="Wrap" AcceptsReturn="True"/>

            <TextBlock x:Name="TxtError" Foreground="Red"
                       FontSize="12" Margin="0,8,0,0"
                       Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="İptal" Width="90" Height="36"
                    Background="#95A5A6" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                    Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave" Content="Kaydet" Width="90" Height="36"
                    Background="#27AE60" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>