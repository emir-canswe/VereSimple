<Page x:Class="VereSimple.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard">

    <ScrollViewer Padding="30">
        <StackPanel>
            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,0,0,25"/>

            <!-- Metrik Kartları -->
            <WrapPanel>
                <!-- Toplam Borç -->
                <Border Width="200" Height="110" Background="#E74C3C"
                        CornerRadius="8" Margin="0,0,15,15">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Toplam Borç" Foreground="White" FontSize="13"/>
                        <TextBlock x:Name="TxtTotalDebt" Text="0 ₺"
                                   Foreground="White" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Toplam Tahsilat -->
                <Border Width="200" Height="110" Background="#27AE60"
                        CornerRadius="8" Margin="0,0,15,15">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Toplam Tahsilat" Foreground="White" FontSize="13"/>
                        <TextBlock x:Name="TxtTotalPayment" Text="0 ₺"
                                   Foreground="White" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Kalan Borç -->
                <Border Width="200" Height="110" Background="#2980B9"
                        CornerRadius="8" Margin="0,0,15,15">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Kalan Borç" Foreground="White" FontSize="13"/>
                        <TextBlock x:Name="TxtRemainingDebt" Text="0 ₺"
                                   Foreground="White" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Toplam Müşteri -->
                <Border Width="200" Height="110" Background="#8E44AD"
                        CornerRadius="8" Margin="0,0,15,15">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Toplam Müşteri" Foreground="White" FontSize="13"/>
                        <TextBlock x:Name="TxtTotalCustomers" Text="0"
                                   Foreground="White" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</Page>