<Window x:Class="VereSimple.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VereSimple — Giriş" Height="350" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#F0F4F8">
        <StackPanel VerticalAlignment="Center" Margin="50,0">

            <TextBlock Text="VereSimple"
                       FontSize="28" FontWeight="Bold"
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>

            <TextBlock Text="Veresiye Takip Sistemi"
                       FontSize="13" Foreground="#7F8C8D"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>

            <TextBlock Text="Kullanıcı Adı" FontSize="13" Foreground="#2C3E50" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtUsername"
                     Height="38" FontSize="14"
                     Padding="8,0"
                     BorderBrush="#BDC3C7" BorderThickness="1"/>

            <TextBlock Text="Şifre" FontSize="13" Foreground="#2C3E50" Margin="0,15,0,5"/>
            <PasswordBox x:Name="TxtPassword"
                         Height="38" FontSize="14"
                         Padding="8,0"
                         BorderBrush="#BDC3C7" BorderThickness="1"/>

            <TextBlock x:Name="TxtError"
                       Foreground="Red" FontSize="12"
                       Margin="0,8,0,0" Visibility="Collapsed"/>

            <Button x:Name="BtnLogin"
                    Content="Giriş Yap"
                    Height="42" Margin="0,20,0,0"
                    FontSize="15" FontWeight="SemiBold"
                    Background="#2980B9" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnLogin_Click"/>
        </StackPanel>
    </Grid>
</Window>