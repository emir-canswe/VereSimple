<Window x:Class="VereSimple.Views.CustomerDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Müşteri Detayı" Height="600" Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Müşteri Adı -->
        <TextBlock x:Name="TxtCustomerName" Grid.Row="0"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#2C3E50" Margin="0,0,0,10"/>

        <!-- Borç Özeti -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,15">
            <Border Background="#E74C3C" CornerRadius="6"
                    Padding="15,8" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Toplam Borç" Foreground="White" FontSize="11"/>
                    <TextBlock x:Name="TxtTotalDebt" Foreground="White"
                               FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#27AE60" CornerRadius="6"
                    Padding="15,8" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Toplam Ödeme" Foreground="White" FontSize="11"/>
                    <TextBlock x:Name="TxtTotalPayment" Foreground="White"
                               FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#2980B9" CornerRadius="6" Padding="15,8">
                <StackPanel>
                    <TextBlock Text="Kalan Borç" Foreground="White" FontSize="11"/>
                    <TextBlock x:Name="TxtRemaining" Foreground="White"
                               FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- İşlem Butonları -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="+ Borç Ekle" Width="110" Height="36"
                    Background="#E74C3C" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"
                    Click="BtnAddDebt_Click"/>
            <Button Content="+ Ödeme Al" Width="110" Height="36"
                    Background="#27AE60" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnAddPayment_Click"/>
        </StackPanel>

        <!-- Hareket Listesi -->
        <DataGrid Grid.Row="3" x:Name="TransactionsGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#BDC3C7" BorderThickness="1"
                  RowHeight="38" FontSize="13"
                  CanUserResizeRows="False"
                  AlternatingRowBackground="#F8F9FA">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tarih"
                    Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="140"/>
                <DataGridTextColumn Header="Tür" Binding="{Binding TypeDisplay}" Width="90"/>
                <DataGridTextColumn Header="Tutar"
                    Binding="{Binding Amount, StringFormat={}{0:N2} ₺}" Width="120"/>
                <DataGridTextColumn Header="Açıklama" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>