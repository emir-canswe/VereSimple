<Window x:Class="VereSimple.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VereSimple — Dashboard" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Üst Bar -->
        <Grid Grid.Row="0" Background="#2C3E50">
            <TextBlock Text="VereSimple — Veresiye Takip"
                       Foreground="White" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="20,0"/>
            <Button x:Name="BtnLogout" Content="Çıkış"
                    HorizontalAlignment="Right" Margin="0,0,20,0"
                    Width="80" Height="32"
                    Background="#E74C3C" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnLogout_Click"/>
        </Grid>

        <!-- Ana İçerik -->
        <Grid Grid.Row="1" Background="#F0F4F8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sol Menü -->
            <StackPanel Grid.Column="0" Background="#34495E" Margin="0">
                <Button x:Name="BtnDashboard" Content="📊  Dashboard"
                        Height="50" Background="Transparent" Foreground="White"
                        BorderThickness="0" HorizontalContentAlignment="Left"
                        Padding="20,0" FontSize="14" Cursor="Hand"
                        Click="BtnDashboard_Click"/>
                <Button x:Name="BtnCustomers" Content="👥  Müşteriler"
                        Height="50" Background="Transparent" Foreground="White"
                        BorderThickness="0" HorizontalContentAlignment="Left"
                        Padding="20,0" FontSize="14" Cursor="Hand"
                        Click="BtnCustomers_Click"/>
            </StackPanel>

            <!-- Sağ İçerik Alanı -->
            <Frame x:Name="MainFrame" Grid.Column="1"
                   NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>